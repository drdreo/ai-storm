{
  "name": "ai-storm",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm --filter @ai-storm/shared build && pnpm --parallel -r dev",
    "dev:backend": "pnpm --filter ai-storm-backend dev",
    "dev:frontend": "pnpm --filter ai-storm-frontend start",
    "start:backend": "pnpm --filter ai-storm-backend start",
    "smoke": "pnpm --filter ai-storm-backend smoke",
    "prepare": "pnpm --filter @ai-storm/shared build"
  }
}
