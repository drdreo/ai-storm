{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ai-storm": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "as",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": ["assets"],
            "styles": ["src/styles.css"],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "yjs",
              "y-indexeddb",
              "classnames",
              "eventemitter3",
              "lodash.isequal",
              "lodash.isequalwith",
              "lodash.throttle",
              "lodash.uniq",
              "lz-string",
              "rbush",
              "react",
              "react-dom",
              "react-dom/client",
              "react/jsx-runtime",
              "use-sync-external-store",
              "use-sync-external-store/shim/index.js",
              "use-sync-external-store/shim/with-selector.js",
              "@xterm/addon-fit",
              "@xterm/xterm"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "16mb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ai-storm:build:production"
            },
            "development": {
              "buildTarget": "ai-storm:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4200,
            "proxyConfig": "proxy.conf.json"
          }
        }
      }
    }
  }
}
